{
    "# ── LazyMicro: VS Code keybindings ─────────────────────────────────────────": "",

    "# ── File Operations ──────────────────────────────────────────────────────────": "",
    "Ctrl-n":            "NewTab",
    "Ctrl-w":            "Quit",
    "Ctrl-s":            "Save",
    "Ctrl-Shift-s":      "SaveAs",

    "# ── Sidebar & Panel ──────────────────────────────────────────────────────────": "",
    "Ctrl-b":            "lua:filemanager.toggle",
    "Ctrl-`":            "TermClose|term",
    "Ctrl-j":            "TermClose|term",

    "# ── Navigation ─ VS Code style ──────────────────────────────────────────────": "",
    "Ctrl-p":            "lua:fzf.fzf",
    "Ctrl-Shift-p":      "CommandMode",
    "Ctrl-g":            "command:goto",
    "Ctrl-Tab":          "NextTab",
    "Ctrl-Shift-Tab":    "PrevTab",
    "Ctrl-1":            "tab 1",
    "Ctrl-2":            "tab 2",
    "Ctrl-3":            "tab 3",
    "Ctrl-4":            "tab 4",
    "Ctrl-5":            "tab 5",

    "# ── Search & Replace ─────────────────────────────────────────────────────────": "",
    "Ctrl-f":            "Find",
    "Ctrl-h":            "FindReplace",
    "Ctrl-Shift-f":      "Find",
    "F3":                "FindNext",
    "Shift-F3":          "FindPrevious",

    "# ── Editing ─ VS Code style ──────────────────────────────────────────────────": "",
    "Ctrl-/":            "lua:comment.comment",
    "Ctrl-Shift-k":      "DeleteLine",
    "Ctrl-d":            "SelectWord",
    "Ctrl-l":            "SelectLine",
    "Alt-Up":            "MoveLinesUp",
    "Alt-Down":          "MoveLinesDown",
    "Alt-Shift-Up":      "DuplicateLine",
    "Alt-Shift-Down":    "DuplicateLine",
    "Ctrl-z":            "Undo",
    "Ctrl-y":            "Redo",
    "Ctrl-Shift-z":      "Redo",
    "Ctrl-x":            "Cut",
    "Ctrl-c":            "Copy",
    "Ctrl-v":            "Paste",
    "Ctrl-a":            "SelectAll",

    "# ── Indentation ─────────────────────────────────────────────────────────────": "",
    "Tab":               "IndentSelection|Indent",
    "Shift-Tab":         "OutdentSelection|Outdent",

    "# ── LSP (F-key palette matches VS Code) ─────────────────────────────────────": "",
    "F2":                "lua:lsp.rename",
    "F12":               "lua:lsp.definition",
    "Shift-F12":         "lua:lsp.references",
    "F8":                "lua:lsp.diagnosticsnext",
    "Ctrl-.":            "lua:lsp.codeaction",
    "Ctrl-Shift-m":      "lua:lsp.diagnosticsall",
    "Ctrl-Space":        "lua:lsp.complete",
    "Shift-F1":          "lua:lsp.hover",

    "# ── Split Panes (VS Code: Ctrl+\\ and Ctrl+number) ──────────────────────────": "",
    "Ctrl-\\":           "VSplit",
    "Ctrl-Shift-\\":     "HSplit",
    "Ctrl-k Ctrl-ArrowLeft":  "PreviousSplit",
    "Ctrl-k Ctrl-ArrowRight": "NextSplit",

    "# ── Cursor Tricks ────────────────────────────────────────────────────────────": "",
    "Ctrl-Home":         "StartOfFile",
    "Ctrl-End":          "EndOfFile",
    "Alt-Left":          "WordLeft",
    "Alt-Right":         "WordRight",
    "Ctrl-Shift-Home":   "SelectToStartOfFile",
    "Ctrl-Shift-End":    "SelectToEndOfFile",

    "# ── Jump to matching bracket (VS Code: Ctrl+Shift+\\) ──────────────────────": "",
    "Ctrl-Shift-m":      "JumpToMatchingBrace",

    "# ── Misc ─────────────────────────────────────────────────────────────────────": "",
    "Ctrl-r":            "ToggleRuler",
    "F1":                "command:help",
    "Escape":            "command-escape"
}
